# Required for diarization.
# Create a read token at https://huggingface.co/settings/tokens and accept the
# diarization model terms referenced by WhisperX upstream.
HF_TOKEN=

# WhisperX runtime settings.
WHISPERX_MODEL=large-v2
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8
WHISPERX_BATCH_SIZE=8
WHISPERX_THREADS=4

# Force language when local accents confuse Whisper's language detector.
# For Singaporean English recordings, keep this as English.
WHISPERX_LANGUAGE=en

# Optional. Use this when WhisperX detects a language without a built-in
# alignment model, for example Malay (`ms`).
# WHISPERX_ALIGN_MODEL=

# Optional local model cache.
# WHISPERX_MODEL_DIR=./models

# Optional local SLM categorization stage.
# This expects an Ollama-compatible local server, for example:
# ollama pull llama3.2:3b
# ollama serve
SLM_ENABLED=false
SLM_PROVIDER=ollama
SLM_MODEL=llama3.2:3b
SLM_BASE_URL=http://127.0.0.1:11434
SLM_PROMPT_FILE=prompts/slm_context.md
SLM_TEMPERATURE=0
SLM_TIMEOUT_SECONDS=180
SLM_MAX_INPUT_CHARS=16000
