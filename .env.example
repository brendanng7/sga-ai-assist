# Required for diarization.
# Create a read token at https://huggingface.co/settings/tokens and accept the
# diarization model terms referenced by WhisperX upstream.
HF_TOKEN=

# WhisperX runtime settings.
WHISPERX_MODEL=large-v2
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8
WHISPERX_BATCH_SIZE=8

# Optional local model cache.
# WHISPERX_MODEL_DIR=./models

